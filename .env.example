# ==============================================================================
# Centralized Environment Variables Template
# Copy this file to .env to configure your local development environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Configuration
# ------------------------------------------------------------------------------
# Note: Use a non-superuser role (e.g. app_user) to ensure Postgres enforces RLS policies.
DATABASE_URL=postgresql+asyncpg://app_user:app_pass@postgres:5432/platform

# Redis Connection URL (Cache, Rate Limiting, Celery Broker)
REDIS_URL=redis://redis-service:6379

# ChromaDB Client Configuration
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# MinIO (S3-Compatible Object Storage) Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password

# OpenAI API Key (Required for embedding/generation in subsequent phases)
OPENAI_API_KEY=your_openai_api_key_here

# Backend Authentication Settings
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256

# Shared Internal Secret for Service-to-Service Communication (e.g. Next.js to FastAPI resolution)
INTERNAL_SECRET=internal-service-secret

# ------------------------------------------------------------------------------
# Frontend Configuration
# ------------------------------------------------------------------------------
# Root Domain for Multi-Tenancy Subdomain Resolution
NEXT_PUBLIC_ROOT_DOMAIN=platform.com
NEXT_PUBLIC_PLATFORM_HOSTNAME=platform.com

# Public API URL for client-side API requests
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Backend service address accessible within the Docker network
BACKEND_URL=http://backend:8000

# NextAuth Authentication Security Secret
NEXTAUTH_SECRET=your_nextauth_secret_here

# Frontend Application URL
NEXTAUTH_URL=http://localhost
